# Agromat External API — products + filters (X-API-Key header)
AGROMAT_API_KEY=your_agromat_api_key_here
AGROMAT_API_BASE_URL=https://www.agromat.ua/api/v1

# Redis / Valkey — для live-каталога, sync state, changes і timeline.
# На VPS використовуйте локальний Redis:
REDIS_URL=redis://127.0.0.1:6379

# Upstash Redis fallback — залишити порожнім, якщо використовується REDIS_URL
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# Daily snapshots зберігаються на диску як .json.gz за останні 30 днів.
# За замовчуванням: <project>/data/product-snapshots
PRODUCT_SNAPSHOTS_DIR=/var/lib/agromat-analytics/product-snapshots

# VPS cron runner
APP_PORT=3000
SYNC_LOG=/var/log/agromat-products-sync.log

# Захищає /api/products/sync — Bearer-токен для cron на VPS і ручного тригера з UI
CRON_SECRET=your_random_secret_here

# Захищає мутації з dashboard (required-attrs, manual sync trigger)
NEXT_PUBLIC_DASHBOARD_SECRET=your_random_dashboard_secret_here

# Supabase (Postgres) — спільна БД з парсером конкурентів (products, price_snapshots, ...)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# AWS S3 — нічний CSV з продажами для інтеграції в dashboard / Looker.
# Мінімальні IAM права: s3:GetObject на arn:aws:s3:::dataset4bq/analysebillsofparsel.csv
# Якщо потрібно перевіряти список файлів у bucket: s3:ListBucket на arn:aws:s3:::dataset4bq
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
# AWS_SESSION_TOKEN=your_temporary_session_token_here
AWS_REGION=eu-central-1
SALES_S3_URL=s3://dataset4bq/analysebillsofparsel.csv
SALES_GROUPS_S3_URL=s3://dataset4bq/inventorygroups.csv

# Внутрішня адреса Flask-парсера (Agromat_Parcer) для проксі /api/parser/reparse
PARCER_INTERNAL_URL=http://127.0.0.1:8080

# URL Flask UI у вкладці «Аналіз цін конкурентів».
# Локально без цієї змінної автоматично використовується http://127.0.0.1:5001/
# NEXT_PUBLIC_PARCER_URL=http://127.0.0.1:5001/

# Пароль, який очікує Flask на /api/run/<action> (env PARSE_PASSWORD у парсері).
# Default у парсері — 'Agromat2026'.
PARCER_RUN_PASSWORD=Agromat2026

# Browser-worker для Сантехшари (Cloudflare/JS challenge)
SANTECHSHARA_PROFILE_DIR=/var/lib/agromat-browser/santechshara-profile
SANTECHSHARA_HEADLESS=true
SANTECHSHARA_FIRST_WAIT_MS=12000
SANTECHSHARA_WAIT_MIN_MS=4500
SANTECHSHARA_WAIT_MAX_MS=12000
# При тимчасовому блокуванні оновлювати сторінку з наростаючою паузою до 10 хвилин.
SANTECHSHARA_BLOCKED_RETRY_WAIT_MS=15000
SANTECHSHARA_BLOCKED_RETRY_MAX_WAIT_MS=60000
SANTECHSHARA_BLOCKED_RETRY_TIMEOUT_MS=600000
# Профілактична пауза після кожних 4 товарів, щоб рідше потрапляти під блокування.
SANTECHSHARA_COOLDOWN_EVERY=4
SANTECHSHARA_COOLDOWN_MIN_MS=30000
SANTECHSHARA_COOLDOWN_MAX_MS=60000
# Швидший обхід категорій: ціна, бренд та артикул беруться зі сторінок листингу.
SANTECHSHARA_CATEGORY_ROOT=/santehnika/
SANTECHSHARA_CATEGORY_WAIT_MS=1500
SANTECHSHARA_CATEGORY_TIMEOUT_MS=45000
SANTECHSHARA_CATEGORY_RETRIES=4

# Простий HTTP-парсер для plitka.ua / leoceramika.com
SIMPLE_PRICE_LIMIT=0
SIMPLE_PRICE_WAIT_MS=200
SIMPLE_PRICE_TIMEOUT_MS=25000
# Щоденний VPS cron запускає Plitka.ua, потім LeoCeramika о 18:00 за Києвом.
SIMPLE_PRICE_LOG=/var/log/agromat-simple-price.log

# Локальний runner для кнопок Сантехшара/Vannaja у dashboard.
# Потрібно лише на ноутбуці користувача, який запускає локальний браузерний парсинг.
AGROMAT_LOCAL_RUNNER_PORT=8765
# Якщо Agromat_Parcer лежить не поруч з Agromat-Analytics:
# AGROMAT_PARSER_REPO=/absolute/path/to/Agromat_Parcer
